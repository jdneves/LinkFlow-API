{
  "info": {
    "name": "LinkFlow — Radar de Produtos",
    "_postman_id": "linkflow-radar-v1",
    "description": "Endpoints do radar de produtos afiliados (GET /api/radar/*). Todos exigem JWT — configure a variável `token` no environment ou use a pasta Auth para obter um.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Access token JWT retornado pelo login"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "description": "Obter token JWT para usar nas demais requisições",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set('token', json.accessToken);",
                  "  console.log('Token salvo na variável {{token}}');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seu@email.com\",\n  \"password\": \"suaSenha123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Faz login e salva automaticamente o `accessToken` na variável `{{token}}` da coleção."
          }
        }
      ]
    },
    {
      "name": "Radar",
      "description": "Endpoints principais do radar de produtos afiliados",
      "item": [
        {
          "name": "Listar produtos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/radar?page=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "radar"],
              "query": [
                {
                  "key": "page",
                  "value": "0",
                  "description": "Número da página (0-based)"
                },
                {
                  "key": "category",
                  "value": "eletronicos",
                  "description": "Filtrar por categoria",
                  "disabled": true
                },
                {
                  "key": "platform",
                  "value": "SHOPEE",
                  "description": "MERCADO_LIVRE | SHOPEE | AMAZON",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "airfryer",
                  "description": "Busca por nome (suporte a fuzzy search)",
                  "disabled": true
                }
              ]
            },
            "description": "Lista paginada de produtos. Filtros opcionais: `category`, `platform` (MERCADO_LIVRE | SHOPEE | AMAZON) e `search` (texto livre). Retorna 20 itens por página."
          }
        },
        {
          "name": "Listar produtos — com filtros",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/radar?category=eletronicos&platform=SHOPEE&search=airfryer&page=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "radar"],
              "query": [
                { "key": "category", "value": "eletronicos" },
                { "key": "platform", "value": "SHOPEE" },
                { "key": "search", "value": "airfryer" },
                { "key": "page", "value": "0" }
              ]
            },
            "description": "Exemplo com todos os filtros ativos simultaneamente."
          }
        },
        {
          "name": "Produtos em alta (trending)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/radar/trending",
              "host": ["{{baseUrl}}"],
              "path": ["api", "radar", "trending"]
            },
            "description": "Retorna os top 6 produtos em alta (`trend = RISING`), ordenados por score decrescente."
          }
        },
        {
          "name": "Buscar produto por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/radar/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "radar", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "",
                  "description": "UUID do produto (ex: 3fa85f64-5717-4562-b3fc-2c963f66afa6)"
                }
              ]
            },
            "description": "Retorna os detalhes completos de um produto pelo seu UUID."
          }
        },
        {
          "name": "Listar categorias",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/radar/categorias",
              "host": ["{{baseUrl}}"],
              "path": ["api", "radar", "categorias"]
            },
            "description": "Retorna todas as categorias distintas existentes no banco. Útil para popular filtros no frontend."
          }
        }
      ]
    }
  ]
}
